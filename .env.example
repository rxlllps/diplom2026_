# Copy this file to .env and fill in real values: cp .env.example .env

# HTTP port (optional, defaults to 8080)
PORT=8080

# Secret used to sign JWT tokens
JWT_SECRET=change-me

# SMTP — contact form mailbox
SMTP_CONTACT_USER=your-contact@example.com
SMTP_CONTACT_PASS=your-password

# SMTP — password-reset mailbox
SMTP_RESET_USER=your-reset@example.com
SMTP_RESET_PASS=your-password
